      "isDeleted": true,
      "boundElements": null,
      "updated": 1777995058459,
      "link": null,
      "locked": false,
      "text": "The model needs to know the order of words, because \"dog bites man\" is different from \"man\nbites dog\". Positional encoding adds position information to each token embedding.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The model needs to know the order of words, because \"dog bites man\" is different from \"man bites dog\". Positional encoding adds position information to each token embedding.",
      "autoResize": false,
      "lineHeight": 1.25
    },
