   "source": [
    "import numpy as np\n",
    "\n",
    "def dot_product(A, B):\n",
    "    return np.dot(A, B)\n",
    "\n",
    "A = [1, 2, 3]\n",
    "B = [4, 5, 6]\n",
    "C = [-4, -5, -6]\n",
    "\n",
    "print(dot_product(A, B))   #  32  — similar direction\n",
    "print(dot_product(A, C))   # -32  — opposite direction"
   ]
  }
 ],
