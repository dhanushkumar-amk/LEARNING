   "source": [
    "def hamming_distance(A, B):\n",
    "    return sum(a != b for a, b in zip(A, B))\n",
    "\n",
    "A = [1, 0, 1, 1, 0]\n",
    "B = [1, 1, 1, 0, 0]\n",
    "C = [1, 0, 1, 1, 0]\n",
    "\n",
    "print(hamming_distance(A, B))  # 2 — 2 positions differ\n",
    "print(hamming_distance(A, C))  # 0 — identical"
   ]
  }
 ],
