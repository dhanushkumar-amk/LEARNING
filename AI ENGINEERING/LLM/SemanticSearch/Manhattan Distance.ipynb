   "source": [
    "import numpy as np\n",
    "\n",
    "def manhattan_distance(A, B):\n",
    "    return np.sum(np.abs(np.array(A) - np.array(B)))\n",
    "\n",
    "A = [1, 2]\n",
    "B = [4, 6]\n",
    "C = [1, 3]\n",
    "\n",
    "print(manhattan_distance(A, B))  # 7  — far\n",
    "print(manhattan_distance(A, C))  # 1  — very close"
   ]
  }
 ],
